PORT=4000
LLM_MODE=mock
ML_API_URL=
ML_API_RETRIES=2
ML_API_TIMEOUT_MS=8000
ML_API_PAYLOAD_MODE=raw
ML_STRICT_VALIDATION=true
ML_API_AUTH_SCHEME=Bearer
ML_API_TOKEN=
ML_API_HEADERS_JSON=
ML_API_RISK_THRESHOLD=0.5
STORAGE_MODE=json
DATABASE_URL=file:/Users/gaurav/csc/prisma/app.db

# WhatsApp Chatbot Configuration
# Provider: twilio | whatsapp_web | mock
WHATSAPP_PROVIDER=twilio
# Twilio credentials (required when WHATSAPP_PROVIDER=twilio)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=
# Meta Cloud API (alternative to Twilio)
WHATSAPP_BUSINESS_NUMBER=
META_WHATSAPP_TOKEN=
META_VERIFY_TOKEN=

# External WhatsApp Pre-check Bot connector
# The bot runs as a separate service (e.g. https://xxx.trycloudflare.com)
# BOT_API_TOKEN must match CSC_API_BEARER_TOKEN set on the bot side
BOT_API_BASE_URL=
BOT_API_TOKEN=
